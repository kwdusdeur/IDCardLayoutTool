<Window x:Class="CardCropperNet.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="350" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 腾讯云配置 -->
        <TextBlock Grid.Row="0" Text="腾讯云 OCR 配置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Secret ID:" Margin="0,0,0,4"/>
            <TextBox x:Name="SecretIdTextBox" Padding="8,6" FontFamily="Consolas"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Secret Key:" Margin="0,0,0,4"/>
            <PasswordBox x:Name="SecretKeyPasswordBox" Padding="8,6" FontFamily="Consolas"/>
        </StackPanel>

        <TextBlock Grid.Row="3" TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,10">
            💡 提示：填写腾讯云密钥后可使用高精度 OCR 裁剪。留空则使用百度/本地方法。
            <LineBreak/>
            获取密钥：<Hyperlink NavigateUri="https://console.cloud.tencent.com/cam/capi" RequestNavigate="Hyperlink_RequestNavigate">
                https://console.cloud.tencent.com/cam/capi
            </Hyperlink>
        </TextBlock>

        <!-- 状态提示 -->
        <TextBlock x:Name="StatusTextBlock" Grid.Row="4" TextWrapping="Wrap" Foreground="#FF6B6B" 
                   VerticalAlignment="Top" Margin="0,10,0,0"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="TestButton" Content="🧪 测试连接" Click="TestButton_Click" Padding="12,6" Margin="0,0,10,0"/>
            <Button x:Name="SaveButton" Content="💾 保存" Click="SaveButton_Click" Padding="12,6" IsDefault="True" Margin="0,0,10,0"/>
            <Button Content="取消" Click="CancelButton_Click" Padding="12,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
