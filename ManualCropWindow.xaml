<Window x:Class="CardCropperNet.ManualCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="手动裁剪 - 依次点击四个角" Height="750" Width="950"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="12">
            <TextBlock x:Name="HintText"
                       Text="请依次点击：① 左上角"
                       FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="↻ 顺时针90°" Click="RotateCW_Click" Padding="12,6" Margin="4"/>
            <Button Content="↺ 逆时针90°" Click="RotateCCW_Click" Padding="12,6" Margin="4"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#9E9E9E" Margin="12">
            <ScrollViewer x:Name="ImageScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          MouseWheel="Scroller_MouseWheel">
                <Canvas x:Name="CropCanvas" ClipToBounds="False"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        Cursor="Cross"
                        RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                    </Canvas.RenderTransform>
                    <Image x:Name="CropImage" Canvas.Left="0" Canvas.Top="0"/>
                    <Polygon x:Name="CropPolygon" Stroke="#3F8EFF" StrokeThickness="2"
                             Fill="#223F8EFF"/>
                </Canvas>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="12">
            <Button Content="✅ 确认裁剪" Click="Confirm_Click" x:Name="ConfirmBtn"
                    Background="#4CAF50" Foreground="White" Padding="20,8" FontSize="14" Margin="8" IsEnabled="False"/>
            <Button Content="🔄 重新点选" Click="Reset_Click" Padding="20,8" FontSize="14" Margin="8"/>
            <Button Content="❌ 取消" Click="Cancel_Click" Padding="20,8" FontSize="14" Margin="8"/>
        </StackPanel>
    </Grid>
</Window>
