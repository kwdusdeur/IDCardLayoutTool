<Window x:Class="CardCropperNet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="证卡裁剪打印工具 - .NET 8 版" Height="820" Width="1420"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 左栏大按钮样式 -->
        <Style x:Key="LeftBigButton" TargetType="Button">
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 右栏带色块的高按钮样式 -->
        <Style x:Key="ColorActionButton" TargetType="Button">
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 列表项样式：选中蓝色半透明底 -->
        <Style x:Key="ImageItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" BorderBrush="#DDDDDD" BorderThickness="1"
                                CornerRadius="4" Background="Transparent" Padding="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#553F8EFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3F8EFF"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#22000000"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 跟随系统：不强制深色，使用默认窗口背景 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：图片列表 -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="拖照片到这里(第1张=正面，第2张=反面)"
                       FontSize="13" FontWeight="Bold"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>

            <!-- 左栏操作按钮：旋转 + 手动裁剪 -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,6">
                <Button Content="↻ 顺时针" Click="RotateCW_Click" Style="{StaticResource LeftBigButton}"/>
                <Button Content="↺ 逆时针" Click="RotateCCW_Click" Style="{StaticResource LeftBigButton}"/>
                <Button Content="✋ 手动裁剪" Click="ManualCrop_Click" Style="{StaticResource LeftBigButton}"/>
            </UniformGrid>

            <!-- ListBox 支持拖矩形框选 + 右键菜单框选 -->
            <ListBox Grid.Row="2" x:Name="ImageListBox"
                     SelectionMode="Extended"
                     ItemContainerStyle="{StaticResource ImageItemContainerStyle}"
                     SelectionChanged="ImageListBox_SelectionChanged"
                     PreviewMouseLeftButtonDown="ImageListBox_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="ImageListBox_PreviewMouseMove"
                     MouseLeftButtonDown="ImageListBox_MouseLeftButtonDown"
                     MouseRightButtonDown="ImageListBox_MouseRightButtonDown"
                     Drop="ImageListBox_Drop"
                     DragOver="ImageListBox_DragOver"
                     AllowDrop="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="100" Height="70" Background="#EEEEEE">
                                <Image Source="{Binding ThumbnailImage}" Stretch="Uniform" Margin="2"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding DisplayLabel}" Foreground="#2266CC"
                                           FontWeight="Bold" FontSize="12"/>
                                <!-- 文件名显示最长36字符，超出不滚动 -->
                                <TextBlock Text="{Binding FileName}"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" 
                                           FontSize="11" MaxWidth="230"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 添加/删除/清空 -->
            <UniformGrid Grid.Row="3" Columns="3" Margin="0,6,0,0">
                <Button Content="➕ 添加" Click="AddImages_Click" Style="{StaticResource LeftBigButton}"/>
                <Button Content="🗑️ 删除" Click="RemoveImage_Click" Style="{StaticResource LeftBigButton}"/>
                <Button Content="🔄 清空" Click="ClearList_Click" Style="{StaticResource LeftBigButton}"/>
            </UniformGrid>
        </Grid>

        <!-- 中间：预览区（灰色背景衬托 A4 白纸，拼版时显示上下页，裁剪预览时不显示） -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="预览区：裁剪 / 拼版效果显示在这里"
                       FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

            <!-- 灰色背景衬托 A4 白纸 -->
            <Border Grid.Row="1" Background="#9E9E9E" BorderBrush="#888888" BorderThickness="1" CornerRadius="4">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Padding="30">
                    <Border Background="White" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <Image x:Name="PreviewImage" Stretch="Uniform" MaxWidth="520" MaxHeight="620"/>
                    </Border>
                </ScrollViewer>
            </Border>

            <!-- 多页浏览控制（只在拼版时显示） -->
            <StackPanel Grid.Row="2" x:Name="PageControlPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8" Visibility="Collapsed">
                <Button x:Name="PrevPageBtn" Content="◀ 上一页" Click="PrevPage_Click" Padding="12,6" Margin="4"/>
                <TextBlock x:Name="PageInfoText" Text="" VerticalAlignment="Center" Margin="12,0" FontSize="13" FontWeight="Bold"/>
                <Button x:Name="NextPageBtn" Content="下一页 ▶" Click="NextPage_Click" Padding="12,6" Margin="4"/>
            </StackPanel>

            <TextBlock Grid.Row="3" x:Name="StatusText" Text=""
                       HorizontalAlignment="Center" Margin="8" FontSize="12" Foreground="#555555"/>
        </Grid>

        <!-- 右侧：工具栏（加宽到300px，添加证卡类型标题，删除所有分隔线） -->
        <Border Grid.Column="2" Margin="10" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel>
                    <!-- 证卡类型（加标题） -->
                    <TextBlock Text="证卡类型" FontSize="14" FontWeight="Bold" Margin="4,0,4,8"/>
                    <StackPanel Margin="0,0,0,16">
                        <RadioButton x:Name="RadioIdCard" Content="身份证" IsChecked="True" Margin="4"/>
                        <RadioButton x:Name="RadioBankCard" Content="银行卡" Margin="4"/>
                        <RadioButton x:Name="RadioDriverLicense" Content="驾驶证" Margin="4"/>
                        <RadioButton x:Name="RadioPassport" Content="护照" Margin="4"/>
                    </StackPanel>

                    <!-- 一键裁剪 -->
                    <Button Content="✂️ 一键裁剪" Click="AutoCrop_Click" Background="#4CAF50" Style="{StaticResource ColorActionButton}"/>
                    <TextBlock x:Name="CropStatusText" Text="" Margin="4,4,4,12" FontSize="11" Foreground="#2E7D32" TextWrapping="Wrap"/>

                    <!-- 明暗度调整 -->
                    <TextBlock Text="拖滑块预览，点「应用」生效" FontSize="11" Foreground="#666666" Margin="4,0,4,8" TextWrapping="Wrap"/>
                    
                    <TextBlock Text="亮部" FontSize="11" Margin="4,4,4,0"/>
                    <Slider x:Name="HighlightSlider" Minimum="-100" Maximum="100" Value="0"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="AdjustmentSlider_ValueChanged"/>
                    <TextBlock Text="{Binding ElementName=HighlightSlider, Path=Value}"
                               HorizontalAlignment="Center" FontSize="10" Foreground="#888888"/>

                    <TextBlock Text="中间调" FontSize="11" Margin="4,8,4,0"/>
                    <Slider x:Name="MidtoneSlider" Minimum="-100" Maximum="100" Value="0"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="AdjustmentSlider_ValueChanged"/>
                    <TextBlock Text="{Binding ElementName=MidtoneSlider, Path=Value}"
                               HorizontalAlignment="Center" FontSize="10" Foreground="#888888"/>

                    <TextBlock Text="暗部" FontSize="11" Margin="4,8,4,0"/>
                    <Slider x:Name="ShadowSlider" Minimum="-100" Maximum="100" Value="0"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="AdjustmentSlider_ValueChanged"/>
                    <TextBlock Text="{Binding ElementName=ShadowSlider, Path=Value}"
                               HorizontalAlignment="Center" FontSize="10" Foreground="#888888"/>

                    <Button Content="🔄 重置调整" Click="ResetAdjustments_Click" Margin="0,8,0,4"/>
                    <Button Content="✔️ 应用调整" Click="ApplyAdjustments_Click" Background="#009688" Style="{StaticResource ColorActionButton}" Margin="0,0,0,16"/>

                    <!-- A4 拼版 -->
                    <Button Content="📄 一键拼版" Click="AutoLayout_Click" Background="#2196F3" Style="{StaticResource ColorActionButton}"/>
                    <TextBlock Text="未选中=按1-2/3-4顺序；选中=按选中顺序。正面上、反面下，间隔55mm" FontSize="10" Margin="4,4,4,16" Foreground="#777777" TextWrapping="Wrap"/>

                    <!-- 导出打印 -->
                    <Button Content="🖨️ 打印" Click="Print_Click" Background="#FF9800" Style="{StaticResource ColorActionButton}"/>
                    <Button Content="📄 导出 PDF" Click="ExportPdf_Click" Style="{StaticResource ColorActionButton}"/>
                    <Button Content="💾 导出图片" Click="ExportImage_Click" Style="{StaticResource ColorActionButton}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
